# Flask
FLASK_ENV=development
SECRET_KEY=change-this-secret-key
JWT_SECRET_KEY=change-this-jwt-secret-key

# Database (SQLite by default, swap for Postgres URL in production)
DATABASE_URL=sqlite:///finance.db

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
# gemini-2.5-flash is the current stable, cost-efficient model (as of mid-2026).
# gemini-1.5-* and gemini-2.0-* models have been shut down by Google — do not use them.
# You can also use "gemini-flash-latest" to always track Google's newest Flash model.
GEMINI_MODEL=gemini-2.5-flash
